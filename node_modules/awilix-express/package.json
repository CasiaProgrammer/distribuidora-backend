{
  "name": "awilix-express",
  "version": "11.0.1",
  "description": "Awilix helpers for Express",
  "main": "lib/index.js",
  "typings": "lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.mjs",
      "require": "./lib/index.js",
      "types": "./lib/index.d.ts",
      "default": "./lib/index.js"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "rimraf lib && tsc -p tsconfig.build.json && rollup -c",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "lint": "eslint --fix 'src/**/*.ts' && prettier --write \"src/**/*.ts\"",
    "cover": "jest --coverage",
    "semantic-release": "semantic-release"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jeffijoe/awilix-express.git"
  },
  "files": [
    "lib",
    "LICENSE.md",
    "README.md"
  ],
  "directories": {
    "lib": "lib"
  },
  "keywords": [],
  "author": "Talysson <talyssonoc@gmail.com>, Jeff Hansen <jeffijoe@hotmail.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/jeffijoe/awilix-express/issues"
  },
  "homepage": "https://github.com/jeffijoe/awilix-express",
  "dependencies": {
    "awilix-router-core": "^4.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@eslint/js": "^9.18.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.2",
    "assert-request": "^1.0.6",
    "awilix": "^12.1.0",
    "babel-jest": "^30.2.0",
    "eslint": "^9.18.0",
    "express": "^5.2.1",
    "jest": "^30.2.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.2",
    "rollup": "^4.57.1",
    "semantic-release": "^25.0.3",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testRegex": "(/__tests__/.*\\.(test|spec))\\.(ts|tsx|js)$",
    "collectCoverageFrom": [
      "src/**/*.ts"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "modulePaths": [
      "src"
    ],
    "coverageDirectory": "<rootDir>/coverage",
    "transform": {
      "\\.(ts|tsx)": [
        "ts-jest",
        {
          "diagnostics": {
            "ignoreCodes": [
              151002
            ]
          }
        }
      ],
      "\\.(js|jsx)": "babel-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "globals": {}
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ],
    "plugins": [
      [
        "@babel/plugin-proposal-decorators",
        {
          "legacy": true
        }
      ]
    ]
  }
}
